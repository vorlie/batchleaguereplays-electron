{
  "name": "batchleaguereplays-electron",
  "version": "1.0.0",
  "description": "Single-window League of Legends replay history explorer and downloader.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@tailwindcss/postcss": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vorlie/batchleaguereplays-electron.git"
  },
  "build": {
    "appId": "com.batchleaguereplays.app",
    "productName": "Batch League Replays",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "vorlie",
        "repo": "batchleaguereplays-electron",
        "vPrefixedTagName": true
      }
    ]
  }
}
